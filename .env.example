# LOCAL ONLY — copy to .env.local. Used when you run the app or scripts on your machine.
# Vercel and Supabase never read this file; set production vars in Vercel dashboard.

# Database — use one:
# Local:  postgresql://USER:PASSWORD@localhost:5432/DATABASE
# Supabase: postgresql://postgres.PROJECT:PASSWORD@...pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Auth (required)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Client (required for app)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Supabase Storage (optional — for product image/video uploads)
# Create buckets "product-images" and "product-videos" in Supabase Dashboard > Storage and set them to public if you want direct public URLs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron jobs — set a long random secret, pass as Bearer token when calling cron routes
CRON_SECRET=

# Firebase Cloud Messaging (optional — push notifications)
# Server (Admin SDK — send + topic subscribe)
FIREBASE_PROJECT_ID = gemx-e8b04
FIREBASE_CLIENT_EMAIL = firebase-adminsdk-fbsvc@gemx-e8b04.iam.gserviceaccount.com
